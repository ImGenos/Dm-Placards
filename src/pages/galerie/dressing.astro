---
import MainLayout from '../../layouts/main-layout.astro'
import ImageGallery from '../../components/ImageGallery.tsx'
import { readdirSync } from 'node:fs';
import { join } from 'node:path';

// Read all images from public/Galerie/dressing at build time
const imagesDir = join(process.cwd(), 'public', 'Galerie', 'dressing');
const files = readdirSync(imagesDir);
const dressingImages = files
  .filter(file => /\.(jpg|jpeg|png|gif|webp)$/i.test(file))
  .map(file => `/Galerie/dressing/${file}`);
---

<MainLayout title = 'DM Placards - Dressing'>
  <section class="w-full bg-[url('/service2.png')] bg-cover bg-center h-[50vh] flex justify-center items-end">
    <div class="py-[30px] lg:py-[41px] px-[60px] lg:px-[152px] flex flex-col justify-center items-center bg-white rounded-tl-[37px] rounded-tr-[37px] gap-2.5">
      <h1 class="text-[30px] leading-[40px] lg:text-[50px] lg:leading-[62px] font-dm capitalize text-primary-200 ">Dressing</h1>
      <p class="text-base lg:text-[22px] lg:leading-[33px] tracking-tight font-jost text-text-gray"> <a href="/">Accueil</a> / <a href="/galerie">Galerie</a> / Dressing </p>
    </div>
  </section>
  <ImageGallery title="Projets Dressing" images={dressingImages} client:load />
</MainLayout>
