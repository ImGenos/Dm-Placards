---
import MainLayout from '../layouts/main-layout.astro'
import QuoteText from '../components/quote.tsx'

---

<MainLayout title='DM Placards - Le Magasin'>

  <!-- Banner Section -->
  <section class="w-full bg-[url('/service1.png')] bg-cover bg-center h-[50vh] flex justify-center items-end">
    <div class="py-[30px] lg:py-[41px] px-[60px] lg:px-[152px] flex flex-col justify-center items-center bg-white rounded-tl-[37px] rounded-tr-[37px] gap-2.5">
      <h1 class="text-[30px] leading-[40px] lg:text-[50px] lg:leading-[62px] font-dm capitalize text-primary-200">Le Magasin</h1>
      <p class="text-base lg:text-[22px] lg:leading-[33px] tracking-tight font-jost text-text-gray">
        <a href="/">Accueil</a> / Le Magasin
      </p>
    </div>
  </section>

  <!-- Main Content Section -->
  <section class="w-full px-12 lg:px-0 pt-[100px] lg:pt-[200px] pb-[100px] lg:pb-[200px] lg:max-w-[1200px] mx-auto flex flex-col items-center justify-center gap-12">
    <h2 class="text-[30px] text-center font-dm tracking-wide capitalize leading-8 md:leading-[62.50px] md:text-[50px] text-text-blue">
      Expositions armoires Bureaux Dressings
    </h2>
    
    <div class="max-w-[900px] text-center space-y-8">
      <h3 class="text-2xl md:text-3xl font-dm text-primary-200">
        DM Placards vous propose
      </h3>
      
      <p class="text-lg md:text-xl font-jost text-text-gray leading-relaxed">
        Différents rangements sur-mesure
      </p>
      
      <div class="text-base md:text-lg font-jost text-text-gray leading-relaxed space-y-2">
        <p>
          Placard, dressing, bibliothèque, sous-pente, commode, bureau, structure de lit, chevet, 
          dessous d'escalier, portes coulissantes, portes ouvrantes, séparation de pièces
        </p>
      </div>
    </div>

    <!-- Gallery Preview -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full mt-16">
      <a href="/galerie/sous-pentes" class="group relative block overflow-hidden rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300">
        <img
          src="/Galerie/sous-pente/1.jpg"
          alt="Sous Pentes"
          class="w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-black bg-opacity-40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <h3 class="text-white text-2xl font-bold">Sous Pentes</h3>
        </div>
      </a>

      <a href="/galerie/dressing" class="group relative block overflow-hidden rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300">
        <img
          src="/Galerie/dressing/1.jpg"
          alt="Dressing"
          class="w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-black bg-opacity-40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <h3 class="text-white text-2xl font-bold">Dressing</h3>
        </div>
      </a>

      <a href="/galerie/bibliotheque" class="group relative block overflow-hidden rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300">
        <img
          src="/Galerie/biblio/1.jpg"
          alt="Bibliothèque"
          class="w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-black bg-opacity-40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <h3 class="text-white text-2xl font-bold">Bibliothèque</h3>
        </div>
      </a>
    </div>

    <!-- Contact CTA -->
    <div class="mt-16 text-center">
      <a 
        href="/contact" 
        class="inline-block bg-primary-200 text-white px-12 py-4 rounded-full font-jost text-lg hover:bg-primary-200/90 transition-colors"
      >
        Visitez Notre Showroom
      </a>
    </div>
  </section>

</MainLayout>
